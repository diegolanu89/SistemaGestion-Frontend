{
	"version": "2.0.0",
	"tasks": [
		{
			"type": "shell",
			"label": "ReactApp IOS",
			"command": "bash",
			"args": ["-c", "export NVM_DIR=\"$HOME/.nvm\" && [ -s \"$NVM_DIR/nvm.sh\" ] && . \"$NVM_DIR/nvm.sh\" && nvm use 22 && yarn dev"],
			"problemMatcher": [],
			"detail": "Inicia el servidor de desarrollo con Node 22 usando NVM.",
			"options": {
				"env": {
					"BROWSER": "none"
				}
			},
			"icon": {
				"color": "terminal.ansiYellow"
			}
		},
		{
			"label": "ReactApp WINDOWS",
			"type": "shell",
			"command": "npm",
			"args": ["run", "dev"],
			"problemMatcher": [],
			"detail": "Inicia el servidor de desarrollo.",
			"options": {
				"env": {
					"BROWSER": "none"
				}
			},
			"icon": {
				"color": "terminal.ansiYellow"
			}
		},
		{
			"label": "Sass IOS",
			"type": "shell",
			"command": "bash",
			"args": ["-c", "source $HOME/.nvm/nvm.sh && nvm use 22 && yarn sass"],
			"problemMatcher": [],
			"detail": "Observa cambios en archivos SCSS y genera CSS.",
			"icon": {
				"color": "terminal.ansiRed"
			}
		},
		{
			"label": "Sass WINDOWS",
			"type": "shell",
			"command": "npm",
			"args": ["run", "sass"],
			"problemMatcher": [],
			"detail": "Observa cambios en archivos SCSS y genera CSS.",
			"icon": {
				"color": "terminal.ansiRed"
			}
		},
		{
			"label": "Cypress",
			"type": "shell",
			"command": "bash",
			"args": ["-c", "source $HOME/.nvm/nvm.sh && nvm use 22 && yarn cypress:open"],
			"problemMatcher": [],
			"detail": "Ejecuta Cypress en modo interactivo para pruebas E2E.",
			"icon": {
				"color": "terminal.ansiGreen"
			}
		},
		{
			"label": "Coverage",
			"type": "shell",
			"command": "bash",
			"args": ["-c", "source $HOME/.nvm/nvm.sh && nvm use 22 && yarn test:coverage"],
			"problemMatcher": [],
			"detail": "Ejecuta las pruebas con Vitest y genera el reporte de cobertura.",
			"icon": {
				"color": "terminal.ansiCyan"
			}
		},
		{
			"label": "Development IOS",
			"dependsOn": ["ReactApp IOS", "Sass IOS"],
			"problemMatcher": [],
			"group": {
				"kind": "test",
				"isDefault": true
			},
			"icon": {
				"id": "arrow-circle-right",
				"color": "terminal.ansiWhite"
			}
		},
		{
			"label": "Development WINDOWS",
			"dependsOn": ["ReactApp WINDOWS", "Sass WINDOWS"],
			"problemMatcher": [],
			"group": {
				"kind": "test",
				"isDefault": true
			},
			"icon": {
				"id": "arrow-circle-right",
				"color": "terminal.ansiWhite"
			}
		}
	]
}
