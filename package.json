{
	"name": "frontapp",
	"private": true,
	"version": "1.0.0",
	"type": "module",
	"scripts": {
		"dev": "vite",
		"preview": "vite preview",
		"typecheck": "tsc --noEmit",
		"dev:strict": "vite & tsc --noEmit --watch",
		"dev:vite": "vite --host 0.0.0.0 --port 5173",
		"android:studio": "npx cap sync android && npx cap open android",
		"android:dev": "export IP=$(ipconfig getifaddr en0) && concurrently -k -n VITE,CAP \"vite --host 0.0.0.0 --port 3000\" \"wait-on tcp:3000 && CAPACITOR_LIVE_RELOAD_URL=http://$IP:3000 cap run android -l --target Pixel_8\"",
		"android:now": "export IP=$(ipconfig getifaddr en0) && concurrently -k -n VITE,CAP \"vite --host 0.0.0.0 --port 3000\" \"wait-on tcp:3000 && CAPACITOR_LIVE_RELOAD_URL=http://$IP:3000 npx cap run android -l\"",
		"ios:update": "vite build && npx cap copy ios",
		"ios:live": "concurrently \"wait-on tcp:3000 && npx cap run ios -l --target='0A43E8B4-ADD8-4D8F-B147-6D6AB7379D75'\"",
		"mobile:live": "concurrently \"yarn android:dev\" \"yarn ios:live\"",
		"dev:mock": "vite --mode development",
		"dev:mongo": "vite --mode production",
		"build": "vite build",
		"build:mock": "vite build --mode development",
		"build:mongo": "vite build --mode production",
		"build-deploy": "yarn build",
		"deploy:mock": "yarn build:mock",
		"deploy:mongo": "yarn build:mongo",
		"test": "vitest",
		"test:watch": "vitest --watch",
		"test:coverage": "vitest run --coverage --passWithNoTests",
		"test:ui": "vitest --ui",
		"cypress:open": "cypress open",
		"cypress:run": "cypress run",
		"lint": "eslint .",
		"format": "prettier --write .",
		"sass": "sass --watch src/sass/main.scss src/css/appStyle.css",
		"sass:build": "sass src/sass/main.scss src/css/appStyle.css",
		"doc:md": "typedoc --options typedoc-markdown.json",
		"doc:html": "typedoc",
		"cap": "cap",
		"android:quick": "vite build && cap copy android && cap run android",
		"android:prod": "vite build && cap copy android && cap run android",
		"android:dev:medium": "cross-env CAP_DEV_URL=http://192.168.1.230:5173 concurrently -k -n VITE,CAP \"vite --host 0.0.0.0\" \"wait-on tcp:5173 && cap run android -l --target Medium_Phone_API_36.1\"",
		"ios": "yarn build && cap copy && cap open ios",
		"init": "yarn cap init 'GolMatch' com.tuorg.prode --web-dir=dist"
	},
	"dependencies": {
		"@capacitor-mlkit/barcode-scanning": "^7.3.0",
		"@capacitor/android": "^7.4.4",
		"@capacitor/camera": "^7.0.2",
		"@capacitor/core": "^7.4.4",
		"@capacitor/ios": "^7.4.4",
		"@capacitor/preferences": "^8.0.0",
		"@capacitor/storage": "^1.2.5",
		"@emotion/react": "^11.14.0",
		"@emotion/styled": "^11.14.0",
		"@fontsource/playfair-display": "^5.1.1",
		"@googlemaps/js-api-loader": "^2.0.2",
		"@mui/icons-material": "^6.1.9",
		"@mui/material": "^6.4.8",
		"@mui/styles": "^6.4.8",
		"@mui/x-date-pickers": "^8.26.0",
		"capacitor-native-biometric": "^4.2.2",
		"cypress": "^15.9.0",
		"firebase": "^12.9.0",
		"firebase-tools": "^15.5.1",
		"framer-motion": "^12.4.10",
		"react": "^19.0.0",
		"react-dom": "^19.0.0",
		"react-google-recaptcha": "^3.1.0",
		"react-icons": "^5.5.0",
		"react-onesignal": "^3.2.2",
		"react-router-dom": "^7.0.1",
		"react-youtube": "^10.1.0",
		"recharts": "^2.15.1",
		"uuid": "^13.0.0",
		"winston": "^3.19.0"
	},
	"devDependencies": {
		"@capacitor/assets": "^3.0.5",
		"@capacitor/cli": "^7.4.4",
		"@eslint/js": "^9.13.0",
		"@testing-library/dom": "^10.4.0",
		"@testing-library/jest-dom": "^6.6.3",
		"@testing-library/react": "^16.0.1",
		"@testing-library/user-event": "^14.5.2",
		"@types/google.maps": "^3.58.1",
		"@types/react": "^18.3.12",
		"@types/react-dom": "^18.3.1",
		"@types/react-google-recaptcha": "^2.1.9",
		"@types/uuid": "^11.0.0",
		"@vitejs/plugin-react": "^4.3.4",
		"@vitest/coverage-v8": "^2.1.6",
		"c8": "^10.1.3",
		"concurrently": "^9.2.1",
		"eslint": "^9.13.0",
		"eslint-config-prettier": "^9.1.0",
		"eslint-plugin-prettier": "^5.2.1",
		"eslint-plugin-react-hooks": "^5.0.0",
		"eslint-plugin-react-refresh": "^0.4.14",
		"globals": "^15.11.0",
		"jsdom": "^25.0.1",
		"msw": "^2.6.6",
		"prettier": "^3.4.1",
		"sass": "^1.81.0",
		"typedoc": "^0.28.5",
		"typedoc-plugin-markdown": "^4.7.0",
		"typescript": "~5.7.2",
		"typescript-eslint": "^8.16.0",
		"vite": "^7.3.1",
		"vite-plugin-pwa": "^1.1.0",
		"vitest": "^3.2.4",
		"wait-on": "^9.0.3"
	},
	"msw": {
		"workerDirectory": [
			"public"
		]
	}
}
