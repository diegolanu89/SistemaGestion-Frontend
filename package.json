{
	"name": "frontapp",
	"private": true,
	"version": "1.0.0",
	"type": "module",
	"scripts": {
		"dev": "vite",
		"preview": "vite preview",
		"typecheck": "tsc --noEmit",
		"build": "vite build",
		"build:mock": "vite build --mode development",
		"build:mongo": "vite build --mode production",
		"build-deploy": "yarn build",
		"test": "vitest",
		"test:watch": "vitest --watch",
		"test:coverage": "vitest run --coverage --passWithNoTests",
		"test:ui": "vitest --ui",
		"cypress:open": "cypress open",
		"cypress:run": "cypress run",
		"lint": "eslint .",
		"format": "prettier --write .",
		"sass": "sass --watch src/sass/main.scss src/css/appStyle.css",
		"sass:build": "sass src/sass/main.scss src/css/appStyle.css",
		"doc:md": "typedoc --options typedoc-markdown.json",
		"doc:html": "typedoc",
		"cap": "cap"
	},
	"dependencies": {
		"@emotion/react": "^11.14.0",
		"@emotion/styled": "^11.14.0",
		"@fontsource/playfair-display": "^5.1.1",
		"@mui/icons-material": "^6.1.9",
		"@mui/material": "^9.0.0",
		"@mui/x-date-pickers": "^8.26.0",
		"framer-motion": "^12.4.10",
		"react": "^19.0.0",
		"react-dom": "^19.0.0",
		"react-google-recaptcha": "^3.1.0",
		"react-icons": "^5.5.0",
		"react-onesignal": "^3.2.2",
		"react-router-dom": "^7.0.1",
		"react-youtube": "^10.1.0",
		"recharts": "^2.15.1",
		"uuid": "^13.0.0",
		"winston": "^3.19.0"
	},
	"devDependencies": {
		"@eslint/js": "^9.13.0",
		"@testing-library/dom": "^10.4.0",
		"@testing-library/jest-dom": "^6.6.3",
		"@testing-library/react": "^16.0.1",
		"@testing-library/user-event": "^14.5.2",
		"@types/google.maps": "^3.58.1",
		"@types/react": "^18.3.12",
		"@types/react-dom": "^18.3.1",
		"@types/react-google-recaptcha": "^2.1.9",
		"@types/uuid": "^11.0.0",
		"@vitejs/plugin-react": "^4.3.4",
		"@vitest/coverage-v8": "^3.2.4",
		"concurrently": "^9.2.1",
		"eslint": "^9.13.0",
		"eslint-config-prettier": "^9.1.0",
		"eslint-plugin-prettier": "^5.2.1",
		"eslint-plugin-react-hooks": "^5.0.0",
		"eslint-plugin-react-refresh": "^0.4.14",
		"globals": "^15.11.0",
		"jsdom": "^25.0.1",
		"msw": "^2.6.6",
		"prettier": "^3.4.1",
		"sass": "^1.81.0",
		"typedoc": "^0.28.5",
		"typedoc-plugin-markdown": "^4.7.0",
		"typescript": "~5.7.2",
		"typescript-eslint": "^8.16.0",
		"vite": "^7.3.1",
		"vite-plugin-pwa": "^1.1.0",
		"vitest": "^3.2.4",
		"wait-on": "^9.0.3"
	},
	"msw": {
		"workerDirectory": [
			"public"
		]
	},
	"packageManager": "yarn@1.22.22+sha512.a6b2f7906b721bba3d67d4aff083df04dad64c399707841b7acf00f6b133b7ac24255f2652fa22ae3534329dc6180534e98d17432037ff6fd140556e2bb3137e"
